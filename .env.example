# Datenbank (Vercel Postgres / Neon)
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Event APIs
# Meetup: kein Key nötig — läuft über öffentliche RSS-Feeds
# ASAI:   kein Key nötig — direktes HTML-Scraping der asai.ac.at Events-Seite
EVENTBRITE_API_KEY=   # https://www.eventbrite.com/platform/api — kostenlose Registrierung

# Security — schützt /api/crawl vor öffentlichem Zugriff
# Generiere mit: openssl rand -hex 32
CRAWL_SECRET=

# Stufe 2 — Newsletter (noch nicht benötigt)
# RESEND_API_KEY=
